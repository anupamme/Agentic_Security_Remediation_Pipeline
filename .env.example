# Direct Anthropic API
ANTHROPIC_API_KEY=your-key-here

# AWS Bedrock (required when llm.provider=bedrock)
# AWS credentials are read from the standard boto3 chain:
# env vars, ~/.aws/credentials, IAM role, etc.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
# Optional: use a named AWS profile instead of env var credentials
# AWS_PROFILE=my-profile

# Optional overrides (all have defaults in config/default.yaml)
# MASR_LLM_MODEL=claude-sonnet-4-20250514
# MASR_LLM_PROVIDER=anthropic
# MASR_ARCHITECTURE=sequential         # sequential | hub_spoke | blackboard
# MASR_MEMORY_STRATEGY=full_context    # full_context | sliding_window | retrieval
# MASR_LOG_LEVEL=INFO
# MASR_AWS_REGION=us-east-1
# MASR_AWS_PROFILE=my-profile
